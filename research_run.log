 ```python
import numpy as np

def is_bit_set(byte, bit_position):
    """Check if a specific bit in a byte is set."""
    return (byte & (1 << bit_position)) != 0

def process_input_bytes(input_bytes, reset_signal):
    """Process the input bytes and generate the expected 'done' signal and 'out_bytes' output.
    
    Args:
        input_bytes (list of int): List of input bytes.
        reset_signal (list of bool): List of reset signals corresponding to each clock cycle.
    
    Returns:
        tuple: (done_signal, out_bytes)
            - done_signal (list of bool): List of 'done' signals for each clock cycle.
            - out_bytes (list of int): List of 24-bit (3-byte) messages for each clock cycle.
    """
    state = 'DISCARD'
    message_buffer = [0, 0, 0]
    done_signal = []
    out_bytes = []

    for i, (byte, reset) in enumerate(zip(input_bytes, reset_signal)):
        if reset:
            state = 'DISCARD'
            message_buffer = [0, 0, 0]
            done_signal.append(False)
            out_bytes.append(0)
            continue

        if state == 'DISCARD':
            if is_bit_set(byte, 3):
                state = 'COLLECT_1'
                message_buffer[0] = byte
            done_signal.append(False)
            out_bytes.append(0)
        elif state == 'COLLECT_1':
            message_buffer[1] = byte
            state = 'COLLECT_2'
            done_signal.append(False)
            out_bytes.append(0)
        elif state == 'COLLECT_2':
            message_buffer[2] = byte
            state = 'DONE'
            done_signal.append(True)
            out_bytes.append((message_buffer[0] << 16) | (message_buffer[1] << 8) | message_buffer[2])
        elif state == 'DONE':
            if is_bit_set(byte, 3):
                state = 'COLLECT_1'
                message_buffer[0] = byte
            else:
                state = 'DISCARD'
            done_signal.append(False)
            out_bytes.append(0)

    return done_signal, out_bytes

# Example usage
input_bytes = [0x00, 0x00, 0x00, 0x00, 0x2C, 0x81, 0x09, 0x6B, 0x0D, 0x8D, 0x6D, 0x12, 0x01, 0x76, 0x3D, 0xED, 0x8C, 0xF9, 0xCE, 0xC5, 0xAA]
reset_signal = [True, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False, False]

done_signal, out_bytes = process_input_bytes(input_bytes, reset_signal)
print("Done Signal:", done_signal)
print("Out Bytes (in hexadecimal):", [f"{byte:06x}" for byte in out_bytes])
```

This Python code defines the core rules for the DUT based on the given problem description. It processes a sequence of input bytes and generates the expected `done` signal and `out_bytes` output. The `process_input_bytes` function takes a list of input bytes and a list of reset signals, and returns the expected `done` signal and `out_bytes` for each clock cycle. The example usage demonstrates how to use this function with a sample input sequence.
