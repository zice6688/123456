import numpy as np

def is_bit_set(byte, bit_position):
    """Check if a specific bit in a byte is set."""
    return (byte & (1 << bit_position)) != 0

def process_byte_stream(input_bytes, reset_signal):
    """
    Process the input byte stream and generate the expected `done` and `out_bytes` signals.
    
    :param input_bytes: List of input bytes (8-bit integers)
    :param reset_signal: List of reset signals (boolean values)
    :return: A tuple (done_signals, out_bytes_signals) where:
             - done_signals is a list of boolean values indicating when `done` should be asserted
             - out_bytes_signals is a list of 24-bit integers representing the 3-byte message
    """
    state = 'idle'
    first_byte = 0
    second_byte = 0
    third_byte = 0
    done_signals = []
    out_bytes_signals = []

    for i, (byte, reset) in enumerate(zip(input_bytes, reset_signal)):
        if reset:
            state = 'idle'
            first_byte = 0
            second_byte = 0
            third_byte = 0
            done_signals.append(False)
            out_bytes_signals.append(0x000000)
        else:
            if state == 'idle':
                if is_bit_set(byte, 3):
                    state = 'first_byte_received'
                    first_byte = byte
                    done_signals.append(False)
                    out_bytes_signals.append(0x000000)
                else:
                    done_signals.append(False)
                    out_bytes_signals.append(0x000000)
            elif state == 'first_byte_received':
                second_byte = byte
                state = 'second_byte_received'
                done_signals.append(False)
                out_bytes_signals.append(0x000000)
            elif state == 'second_byte_received':
                third_byte = byte
                state = 'third_byte_received'
                done_signals.append(False)
                out_bytes_signals.append(0x000000)
            elif state == 'third_byte_received':
                done_signals.append(True)
                out_bytes_signals.append((first_byte << 16) | (second_byte << 8) | third_byte)
                if is_bit_set(byte, 3):
                    state = 'first_byte_received'
                    first_byte = byte
                    second_byte = 0
                    third_byte = 0
                else:
                    state = 'idle'
            else:
                raise ValueError("Invalid state: {}".format(state))

    return done_signals, out_bytes_signals

# Example usage
input_bytes = [0b00000000, 0b00000000, 0b00010010, 0b00001001, 0b00000011,  # Discard, First byte, Second byte, Third byte
               0b00000000, 0b00000000, 0b00010010, 0b00001001, 0b00000011]  # Another message
reset_signal = [True, False, False, False, False, False, False, False, False, False]

done_signals, out_bytes_signals = process_byte_stream(input_bytes, reset_signal)

print("Done Signals:", done_signals)
print("Out Bytes Signals:", out_bytes_signals)
```

