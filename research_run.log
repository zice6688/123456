module top_module (
    input clk,
    input [7:0] in,
    input reset,
    output reg [23:0] out_bytes,
    output reg done
);

    typedef enum logic [1:0] {
        IDLE,
        BYTE1,
        BYTE2,
        BYTE3
    } state_t;

    state_t state, next_state;
    reg [23:0] message;
    reg [1:0] byte_count;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= IDLE;
            out_bytes <= 24'b0;
            done <= 0;
            message <= 24'b0;
            byte_count <= 0;
        end else begin
            state <= next_state;
            case (state)
                IDLE: begin
                    if (in[3]) begin
                        message <= {in, 16'b0};
                        byte_count <= 1;
                        next_state <= BYTE1;
                    end else begin
                        next_state <= IDLE;
                    end
                end
                BYTE1: begin
                    if (byte_count == 1) begin
                        message <= {message[15:8], in, 8'b0};
                        byte_count <= 2;
                        next_state <= BYTE2;
                    end else begin
                        next_state <= BYTE1;
                    end
                end
                BYTE2: begin
                    if (byte_count == 2) begin
                        message <= {message[7:0], in};
                        byte_count <= 3;
                        next_state <= BYTE3;
                    end else begin
                        next_state <= BYTE2;
                    end
                end
                BYTE3: begin
                    out_bytes <= message;
                    done <= 1;
                    next_state <= IDLE;
                end
            endcase
        end
    end

    always @(*) begin
        case (state)
            IDLE: begin
                done = 0;
            end
            BYTE1, BYTE2: begin
                done = 0;
            end
            BYTE3: begin
                done = 1;
            end
        endcase
    end

endmodule
